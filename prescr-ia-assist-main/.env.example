# Copy this file to .env and fill in your own values.
# .env is ignored by git — never commit it.

# Supabase project — public values, safe to share even in this example file
SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_PUBLISHABLE_KEY="eyJ...your-anon-key..."

VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJ...your-anon-key..."
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_ID"

# NEVER put SUPABASE_SERVICE_ROLE_KEY or LOVABLE_API_KEY here.
# Those secrets live in the Supabase dashboard vault and are injected at
# runtime into edge functions via Deno.env.get().
