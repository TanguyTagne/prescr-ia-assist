{
  "name": "asclion-desktop",
  "version": "1.1.0",
  "description": "Asclion — Assistant Pharmacie intelligent",
  "main": "main.js",
  "author": "Asclion",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "postinstall": "node ./scripts/build-native.js",
    "rebuild:native": "node ./scripts/build-native.js"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "node-addon-api": "^7.1.0",
    "node-hid": "^3.1.2",
    "serialport": "^12.0.0",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "node-gyp": "^10.2.0"
  },
  "build": {
    "appId": "com.asclion.desktop",
    "productName": "Asclion",
    "directories": {
      "output": "dist"
    },
    "artifactName": "Asclion-Setup.${ext}",
    "asarUnpack": [
      "node_modules/uiohook-napi/**/*",
      "node_modules/node-hid/**/*",
      "node_modules/node-addon-api/**/*",
      "node_modules/bindings/**/*",
      "node_modules/serialport/**/*",
      "node_modules/@serialport/**/*",
      "native/rawinput/build/Release/*.node",
      "native/rawinput/index.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Asclion",
      "runAfterFinish": true,
      "include": "installer.nsh"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "TanguyTagne",
      "repo": "prescr-ia-assist"
    }
  }
}
